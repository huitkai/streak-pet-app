# URL gốc của app khi chạy production — dùng để build link xác nhận email
# trỏ đúng về domain thật thay vì localhost. Nhớ set biến này trong
# Environment Variables trên Render, và thêm URL này (kèm /auth/callback)
# vào Supabase Dashboard -> Authentication -> URL Configuration -> Redirect URLs.
NEXT_PUBLIC_SITE_URL=https://streak-pet-app.onrender.com

# API key của Tenor (https://tenor.com/gifapi/documentation#quickstart-apikey)
# — dùng cho tab "GIF" trong bộ chọn nhãn dán (StickerPicker). CHỈ đọc ở
# server (app/api/gif/route.ts), không bao giờ lộ ra client. Nếu để trống,
# tab GIF vẫn hiện nhưng báo "chưa cấu hình" thay vì lỗi khó hiểu.
TENOR_API_KEY=
